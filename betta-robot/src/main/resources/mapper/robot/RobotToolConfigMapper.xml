<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.betta.robot.mapper.RobotToolConfigMapper">
    
    <resultMap type="RobotToolConfig" id="RobotToolConfigResult">
        <result property="id"    column="id"    />
        <result property="configName"    column="config_name"    />
        <result property="className"    column="class_name"    />
        <result property="toolParams"    column="tool_params"    />
        <result property="keywords"    column="keywords"    />
        <result property="priority"    column="priority"    />
        <result property="description"    column="description"    />
        <result property="prompt"    column="prompt"    />
        <result property="dtoClass"    column="dto_class"    />
        <result property="llmConfigId"    column="llm_config_id"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectRobotToolConfigVo">
        select id, config_name, class_name, tool_params, keywords, priority, description, prompt, dto_class, llm_config_id, status, remark, create_by, create_time, update_by, update_time from robot_tool_config
    </sql>

    <select id="selectRobotToolConfigList" parameterType="RobotToolConfig" resultMap="RobotToolConfigResult">
        <include refid="selectRobotToolConfigVo"/>
        <where>  
            <if test="configName != null  and configName != ''"> and config_name like concat('%', #{configName}, '%')</if>
            <if test="className != null  and className != ''"> and class_name like concat('%', #{className}, '%')</if>
            <if test="toolParams != null  and toolParams != ''"> and tool_params = #{toolParams}</if>
            <if test="keywords != null  and keywords != ''"> and keywords = #{keywords}</if>
            <if test="priority != null "> and priority = #{priority}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="prompt != null  and prompt != ''"> and prompt = #{prompt}</if>
            <if test="dtoClass != null  and dtoClass != ''"> and dto_class = #{dtoClass}</if>
            <if test="llmConfigId != null "> and llm_config_id = #{llmConfigId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectRobotToolConfigById" parameterType="Long" resultMap="RobotToolConfigResult">
        <include refid="selectRobotToolConfigVo"/>
        where id = #{id}
    </select>

    <insert id="insertRobotToolConfig" parameterType="RobotToolConfig" useGeneratedKeys="true" keyProperty="id">
        insert into robot_tool_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="configName != null and configName != ''">config_name,</if>
            <if test="className != null and className != ''">class_name,</if>
            <if test="toolParams != null">tool_params,</if>
            <if test="keywords != null">keywords,</if>
            <if test="priority != null">priority,</if>
            <if test="description != null">description,</if>
            <if test="prompt != null">prompt,</if>
            <if test="dtoClass != null">dto_class,</if>
            <if test="llmConfigId != null">llm_config_id,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="configName != null and configName != ''">#{configName},</if>
            <if test="className != null and className != ''">#{className},</if>
            <if test="toolParams != null">#{tool_params},</if>
            <if test="keywords != null">#{keywords},</if>
            <if test="priority != null">#{priority},</if>
            <if test="description != null">#{description},</if>
            <if test="prompt != null">#{prompt},</if>
            <if test="dtoClass != null">#{dtoClass},</if>
            <if test="llmConfigId != null">#{llmConfigId},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateRobotToolConfig" parameterType="RobotToolConfig">
        update robot_tool_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="configName != null and configName != ''">config_name = #{configName},</if>
            <if test="className != null and className != ''">class_name = #{className},</if>
            <if test="toolParams != null">tool_params = #{toolParams},</if>
            <if test="keywords != null">keywords = #{keywords},</if>
            <if test="priority != null">priority = #{priority},</if>
            <if test="description != null">description = #{description},</if>
            <if test="prompt != null">prompt = #{prompt},</if>
            <if test="dtoClass != null">dto_class = #{dtoClass},</if>
            <if test="llmConfigId != null">llm_config_id = #{llmConfigId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteRobotToolConfigById" parameterType="Long">
        delete from robot_tool_config where id = #{id}
    </delete>

    <delete id="deleteRobotToolConfigByIds" parameterType="String">
        delete from robot_tool_config where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>