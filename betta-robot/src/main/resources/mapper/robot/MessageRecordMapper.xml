<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.betta.robot.mapper.MessageRecordMapper">

    <resultMap type="com.betta.robot.domain.MessageRecord" id="MessageRecordResult">
        <id     property="id"           column="id"            />
        <result property="configId"      column="config_id"    />
        <result property="channelType"   column="channel_type" />
        <result property="direction"     column="direction"    />
        <result property="content"       column="content"      />
        <result property="replyContent"  column="reply_content"/>
        <result property="chatId"        column="chat_id"      />
        <result property="userId"        column="user_id"      />
        <result property="messageId"     column="message_id"    />
        <result property="parsedIntent"  column="parsed_intent"/>
        <result property="parsedJson"    column="parsed_json"  />
        <result property="status"        column="status"       />
        <result property="errorMsg"      column="error_msg"   />
        <result property="createTime"    column="create_time"  />
    </resultMap>

    <sql id="selectVo">
        select id, config_id, channel_type, direction, content, reply_content, chat_id, user_id, message_id,
               parsed_intent, parsed_json, status, error_msg, create_time
        from message_record
    </sql>

    <select id="selectList" parameterType="com.betta.robot.domain.MessageRecord" resultMap="MessageRecordResult">
        <include refid="selectVo"/>
        <where>
            <if test="configId != null"> and config_id = #{configId}</if>
            <if test="channelType != null and channelType != ''"> and channel_type = #{channelType}</if>
            <if test="direction != null and direction != ''"> and direction = #{direction}</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectById" parameterType="Long" resultMap="MessageRecordResult">
        <include refid="selectVo"/>
        where id = #{id}
    </select>

    <insert id="insert" parameterType="com.betta.robot.domain.MessageRecord" useGeneratedKeys="true" keyProperty="id">
        insert into message_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="configId != null">config_id,</if>
            <if test="channelType != null">channel_type,</if>
            <if test="direction != null">direction,</if>
            <if test="content != null">content,</if>
            <if test="replyContent != null">reply_content,</if>
            <if test="chatId != null">chat_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="messageId != null">message_id,</if>
            <if test="parsedIntent != null">parsed_intent,</if>
            <if test="parsedJson != null">parsed_json,</if>
            <if test="status != null">status,</if>
            <if test="errorMsg != null">error_msg,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="configId != null">#{configId},</if>
            <if test="channelType != null">#{channelType},</if>
            <if test="direction != null">#{direction},</if>
            <if test="content != null">#{content},</if>
            <if test="replyContent != null">#{replyContent},</if>
            <if test="chatId != null">#{chatId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="messageId != null">#{messageId},</if>
            <if test="parsedIntent != null">#{parsedIntent},</if>
            <if test="parsedJson != null">#{parsedJson},</if>
            <if test="status != null">#{status},</if>
            <if test="errorMsg != null">#{errorMsg},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="update" parameterType="com.betta.robot.domain.MessageRecord">
        update message_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="replyContent != null">reply_content = #{replyContent},</if>
            <if test="parsedIntent != null">parsed_intent = #{parsedIntent},</if>
            <if test="parsedJson != null">parsed_json = #{parsedJson},</if>
            <if test="status != null">status = #{status},</if>
            <if test="errorMsg != null">error_msg = #{errorMsg},</if>
        </trim>
        where id = #{id}
    </update>
</mapper>
