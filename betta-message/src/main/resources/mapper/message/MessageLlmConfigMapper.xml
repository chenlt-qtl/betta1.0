    <select id="selectList" parameterType="com.betta.message.domain.MessageLlmConfig" resultMap="MessageLlmConfigResult">
        <include refid="selectVo"/>
        <where>
            <if test="configName != null and configName != ''"> and config_name like concat('%', #{configName}, '%')</if>
            <if test="provider != null and provider != ''"> and provider = #{provider}</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by id desc
