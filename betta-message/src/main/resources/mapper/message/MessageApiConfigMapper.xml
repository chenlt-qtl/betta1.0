<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.betta.message.mapper.MessageApiConfigMapper">

    <resultMap type="com.betta.message.domain.MessageApiConfig" id="MessageApiConfigResult">
        <id     property="id"              column="id"              />
        <result property="configName"      column="config_name"     />
        <result property="apiUrl"          column="api_url"         />
        <result property="apiParams"       column="api_params"      />
        <result property="keywords"         column="keywords"        />
        <result property="priority"        column="priority"        />
        <result property="description"     column="description"     />
        <result property="prompt"          column="prompt"          />
        <result property="llmConfigId"     column="llm_config_id"  />
        <result property="status"          column="status"          />
        <result property="remark"          column="remark"          />
        <result property="createBy"        column="create_by"       />
        <result property="createTime"      column="create_time"     />
        <result property="updateBy"        column="update_by"       />
        <result property="updateTime"      column="update_time"     />
    </resultMap>

    <sql id="selectVo">
        select id, config_name, api_url, api_params, keywords, priority, description,
               prompt, llm_config_id, status, remark, create_by, create_time, update_by, update_time
        from message_api_config
    </sql>

    <select id="selectList" parameterType="com.betta.message.domain.MessageApiConfig" resultMap="MessageApiConfigResult">
        <include refid="selectVo"/>
        <where>
            <if test="configName != null and configName != ''"> and config_name like concat('%', #{configName}, '%')</if>
            <if test="keywords != null and keywords != ''"> and keywords like concat('%', #{keywords}, '%')</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by priority desc, id desc
    </select>

    <select id="selectById" parameterType="Long" resultMap="MessageApiConfigResult">
        <include refid="selectVo"/>
        where id = #{id}
    </select>

    <insert id="insert" parameterType="com.betta.message.domain.MessageApiConfig" useGeneratedKeys="true" keyProperty="id">
        insert into message_api_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="configName != null">config_name,</if>
            <if test="apiUrl != null">api_url,</if>
            <if test="apiParams != null">api_params,</if>
            <if test="keywords != null">keywords,</if>
            <if test="priority != null">priority,</if>
            <if test="description != null">description,</if>
            <if test="prompt != null">prompt,</if>
            <if test="llmConfigId != null">llm_config_id,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="configName != null">#{configName},</if>
            <if test="apiUrl != null">#{apiUrl},</if>
            <if test="apiParams != null">#{apiParams},</if>
            <if test="keywords != null">#{keywords},</if>
            <if test="priority != null">#{priority},</if>
            <if test="description != null">#{description},</if>
            <if test="prompt != null">#{prompt},</if>
            <if test="llmConfigId != null">#{llmConfigId},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="update" parameterType="com.betta.message.domain.MessageApiConfig">
        update message_api_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="configName != null">config_name = #{configName},</if>
            <if test="apiUrl != null">api_url = #{apiUrl},</if>
            <if test="apiParams != null">api_params = #{apiParams},</if>
            <if test="keywords != null">keywords = #{keywords},</if>
            <if test="priority != null">priority = #{priority},</if>
            <if test="description != null">description = #{description},</if>
            <if test="prompt != null">prompt = #{prompt},</if>
            <if test="llmConfigId != null">llm_config_id = #{llmConfigId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from message_api_config where id = #{id}
    </delete>
</mapper>
